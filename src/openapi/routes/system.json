{
  "openapi": "3.0.0",
  "info": {
    "title": "Customer Feedback API",
    "description": "RESTful API for customer feedback management system",
    "version": "1.0.0",
    "contact": {
      "name": "API Support"
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "Bearer token (user or admin JWT)"
      }
    },
    "schemas": {}
  },
  "paths": {
    "/health": {
      "get": {
        "responses": {
          "200": {
            "description": "Default Response"
          }
        }
      }
    },
    "/api/storage/signed-upload-url": {
      "post": {
        "tags": [
          "Storage"
        ],
        "description": "Generate a signed upload URL for GCS",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "contentType": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 128
                  },
                  "size": {
                    "type": "integer",
                    "exclusiveMinimum": 0,
                    "maximum": 9007199254740991
                  }
                },
                "required": [
                  "contentType",
                  "size"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Signed upload URL generated",
            "content": {
              "application/json": {
                "schema": {
                  "description": "Signed upload URL generated",
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "object",
                      "properties": {
                        "uploadUrl": {
                          "type": "string"
                        },
                        "fileUrl": {
                          "type": "string"
                        },
                        "requiredHeaders": {
                          "type": "object",
                          "properties": {
                            "Content-Type": {
                              "type": "string"
                            }
                          },
                          "required": [
                            "Content-Type"
                          ]
                        },
                        "objectPath": {
                          "type": "string"
                        },
                        "expiresAt": {
                          "type": "string",
                          "format": "date-time",
                          "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z))$"
                        },
                        "uploadConstraints": {
                          "type": "object",
                          "properties": {
                            "scope": {
                              "type": "string",
                              "enum": [
                                "user",
                                "anonymous"
                              ]
                            },
                            "maxUploadSizeBytes": {
                              "type": "integer",
                              "minimum": 0,
                              "maximum": 9007199254740991
                            },
                            "allowedContentTypes": {
                              "type": "array",
                              "items": {
                                "type": "string"
                              }
                            },
                            "signedUrlExpiresSeconds": {
                              "type": "integer",
                              "exclusiveMinimum": 0,
                              "maximum": 9007199254740991
                            },
                            "rateLimitWindowSeconds": {
                              "type": "integer",
                              "exclusiveMinimum": 0,
                              "maximum": 9007199254740991
                            }
                          },
                          "required": [
                            "scope",
                            "maxUploadSizeBytes",
                            "allowedContentTypes",
                            "signedUrlExpiresSeconds",
                            "rateLimitWindowSeconds"
                          ]
                        }
                      },
                      "required": [
                        "uploadUrl",
                        "fileUrl",
                        "requiredHeaders",
                        "objectPath",
                        "expiresAt",
                        "uploadConstraints"
                      ]
                    },
                    "meta": {}
                  }
                }
              }
            }
          },
          "400": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "string",
                      "example": "AUTH_UNAUTHORIZED"
                    },
                    "message": {
                      "type": "string",
                      "example": "Missing or invalid authorization header"
                    },
                    "details": {
                      "type": "object"
                    }
                  },
                  "required": [
                    "code",
                    "message"
                  ]
                }
              }
            }
          },
          "401": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "string",
                      "example": "AUTH_UNAUTHORIZED"
                    },
                    "message": {
                      "type": "string",
                      "example": "Missing or invalid authorization header"
                    },
                    "details": {
                      "type": "object"
                    }
                  },
                  "required": [
                    "code",
                    "message"
                  ]
                }
              }
            }
          },
          "429": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "string",
                      "example": "AUTH_UNAUTHORIZED"
                    },
                    "message": {
                      "type": "string",
                      "example": "Missing or invalid authorization header"
                    },
                    "details": {
                      "type": "object"
                    }
                  },
                  "required": [
                    "code",
                    "message"
                  ]
                }
              }
            }
          },
          "500": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "string",
                      "example": "AUTH_UNAUTHORIZED"
                    },
                    "message": {
                      "type": "string",
                      "example": "Missing or invalid authorization header"
                    },
                    "details": {
                      "type": "object"
                    }
                  },
                  "required": [
                    "code",
                    "message"
                  ]
                }
              }
            }
          }
        }
      }
    }
  },
  "servers": [
    {
      "url": "http://localhost:8080",
      "description": "Development"
    },
    {
      "url": "https://australia-southeast2-docker.pkg.dev/customer-feedback-api",
      "description": "Production"
    }
  ]
}