# Cloud Run base URL, e.g. https://feedback-api-xxxx.a.run.app
VITE_API_BASE_URL=

# Optional API key sent as x-api-key header (public to browser, do NOT put secret credentials here)
VITE_API_KEY=

# Cloud Run endpoint to request a signed upload URL for Cloud Storage
VITE_SIGNED_UPLOAD_PATH=/api/storage/signed-upload-url

# Cloud Run endpoint to submit feedback metadata
VITE_FEEDBACK_SUBMIT_PATH=/api/feedback
